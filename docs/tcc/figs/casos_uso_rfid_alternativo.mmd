---
flowchart LR
    subgraph AtoresEsquerda[" "]
        direction TB
        Tecnico(("Usuário/Técnico"))
        Admin(("Administrador"))
    end

    subgraph Sistema["Sistema Web de Inventário RFID"]
        direction TB

        UCAuth["Autenticar usuário"]
        UCPainel["Consultar painel inicial"]
        UCLeitores["Consultar leitores RFID"]
        UCAuditorias["Consultar auditorias"]
        UCInconsistenciasConsulta["Consultar inconsistências"]
        UCPatrimonio["Consultar patrimônio"]
        UCLog["Consultar log operacional"]

        UCCadastros["Gerenciar locais,<br/>leitores e itens"]
        UCAuditoria["Executar auditoria<br/>patrimonial"]
        UCSimulacao["Processar simulação<br/>de auditoria"]
        UCResolver["Resolver inconsistência"]
        UCSenha["Trocar senha"]
        UCUsuarios["Gerenciar usuários<br/>e permissões"]

        UCComandoPolling["Consultar comando<br/>de leitura"]
        UCComandoDireto["Enviar comando direto<br/>de leitura"]
        UCTags["Enviar leitura<br/>de tags"]
        UCProcessarAuditoria["Processar auditoria<br/>com tags"]
        UCDivergencias["Registrar divergências"]
    end

    subgraph AtoresDireita[" "]
        direction TB
        Comunicador(("Comunicador intermediário<br/>(validação com leitor USB)"))
        Leitor(("Leitor/Gateway RFID<br/>(fluxo proposto com rede)"))
    end

    Admin --> Tecnico

    Tecnico --> UCAuth
    Tecnico --> UCPainel
    Tecnico --> UCLeitores
    Tecnico --> UCAuditorias
    Tecnico --> UCInconsistenciasConsulta
    Tecnico --> UCPatrimonio
    Tecnico --> UCLog
    Tecnico --> UCCadastros
    Tecnico --> UCAuditoria
    Tecnico --> UCSimulacao
    Tecnico --> UCResolver
    Tecnico --> UCSenha

    Admin --> UCUsuarios

    UCComandoPolling --> Comunicador
    Comunicador --> UCTags

    UCComandoDireto --> Leitor
    Leitor --> UCTags

    UCAuditoria -. "&lt;&lt;include&gt;&gt;" .-> UCComandoDireto
    UCTags -. "gera/atualiza" .-> UCProcessarAuditoria
    UCProcessarAuditoria -. "se houver divergência" .-> UCDivergencias
    UCDivergencias -. "alimenta" .-> UCInconsistenciasConsulta

    style AtoresEsquerda fill:transparent,stroke:transparent,color:transparent
    style AtoresDireita fill:transparent,stroke:transparent,color:transparent
